JOBS_AI_ENV=dev
JOBS_AI_PROFILE=default
# Optional override:
# JOBS_AI_DB_BACKEND=sqlite
# JOBS_AI_DB_BACKEND=postgres
JOBS_AI_SQLITE_PATH=data/jobs_ai.db
# Backward-compatible alias for JOBS_AI_SQLITE_PATH:
# JOBS_AI_DB_PATH=data/jobs_ai.db
# For Neon/Postgres mode, prefer DATABASE_URL. Example:
# DATABASE_URL=postgresql://user:password@ep-your-neon-host.us-east-2.aws.neon.tech/neondb?sslmode=require
# Optional alternative pieces if you do not want a single DATABASE_URL:
# PGHOST=ep-your-neon-host.us-east-2.aws.neon.tech
# PGPORT=5432
# PGDATABASE=neondb
# PGUSER=neondb_owner
# PGPASSWORD=replace-me
# PGSSLMODE=require
# Optional: point one resume variant directly at a real file.
# JOBS_AI_RESUME_DATA_ENGINEERING_PATH=/absolute/path/to/data-engineering-resume.pdf
# Optional: JSON object mapping variant keys to files, for example:
# {"data-engineering": "/absolute/path/to/data-engineering-resume.pdf"}
# JOBS_AI_RESUME_MAP_PATH=.jobs_ai_resume_paths.json
